{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python:*)",
      "Bash(.venv/bin/pip:*)",
      "Bash(python3:*)",
      "Bash(ffprobe:*)",
      "Bash(ffmpeg:*)",
      "Bash(mkdir:*)",
